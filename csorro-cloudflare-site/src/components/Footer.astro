---
import B12Link from './B12Link.astro';
---

<footer class="border-t border-border/30 bg-card/40 backdrop-blur">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-12">
      <div>
        <h3 class="text-lg font-bold text-foreground mb-3">Cristian Sorensen</h3>
        <p class="text-sm text-muted-foreground leading-relaxed">
          Production Manager, Technical Project Manager, and Gaming Operations Specialist. Helping teams scale ambitious projects.
        </p>
      </div>

      <div>
        <h4 class="text-sm font-bold text-accent mb-4 uppercase tracking-widest">Navigation</h4>
        <ul class="space-y-2">
          <li><a href="/#about" class="text-sm text-muted-foreground hover:text-accent transition-colors duration-200">About</a></li>
          <li><a href="/#experience" class="text-sm text-muted-foreground hover:text-accent transition-colors duration-200">Experience</a></li>
          <li><a href="/#projects" class="text-sm text-muted-foreground hover:text-accent transition-colors duration-200">Projects</a></li>
          <li><a href="/#contact" class="text-sm text-muted-foreground hover:text-accent transition-colors duration-200">Contact</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-sm font-bold text-accent mb-4 uppercase tracking-widest">Social</h4>
        <ul class="space-y-2">
          <li><a href="https://youtube.com/@sorroplayz" target="_blank" rel="noopener noreferrer" class="text-sm text-muted-foreground hover:text-accent transition-colors duration-200">YouTube @sorroplayz</a></li>
          <li><a href="https://discord.gg/drsQSNBrDZ" target="_blank" rel="noopener noreferrer" class="text-sm text-muted-foreground hover:text-accent transition-colors duration-200">Discord</a></li>
          <li><a href="https://www.linkedin.com/in/cristian-sorensen-671367177/" target="_blank" rel="noopener noreferrer" class="text-sm text-muted-foreground hover:text-accent transition-colors duration-200">LinkedIn</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-sm font-bold text-accent mb-4 uppercase tracking-widest">Email</h4>
        <a href="mailto:contact@csorro.co.uk" class="text-sm font-semibold text-foreground hover:text-accent transition-colors duration-200 break-all">
          contact@csorro.co.uk
        </a>
      </div>
    </div>

    <div class="border-t border-border/30 pt-8">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-xs text-muted-foreground">
          © 2026 Cristian Sorensen. All rights reserved.
        </p>
        <B12Link />
      </div>
    </div>
  </div>
</footer>
