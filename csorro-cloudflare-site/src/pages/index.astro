---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import RequiredB12HeadScripts from '../components/RequiredB12HeadScripts.astro';
import RequiredB12FooterScripts from '../components/RequiredB12FooterScripts.astro';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>Cristian Sorensen - Production Manager & Technical Operations Lead</title>
    <meta name="description" content="Premium portfolio of Cristian Sorensen—Production Manager, Technical Project Manager, and Gaming Operations Specialist. 12+ years leading production, technical operations, and infrastructure delivery at scale." />
    <RequiredB12HeadScripts />
    <style>
      @keyframes fadeInDown {
        from {
          opacity: 0;
          transform: translateY(-20px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      @keyframes fadeInUp {
        from {
          opacity: 0;
          transform: translateY(20px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      @keyframes slideInRight {
        from {
          opacity: 0;
          transform: translateX(30px);
        }
        to {
          opacity: 1;
          transform: translateX(0);
        }
      }
      @keyframes glow {
        0%, 100% { text-shadow: 0 0 20px rgba(245, 158, 11, 0.3), 0 0 40px rgba(245, 158, 11, 0.1); }
        50% { text-shadow: 0 0 30px rgba(245, 158, 11, 0.5), 0 0 60px rgba(245, 158, 11, 0.2); }
      }
      .animate-fade-in-down {
        animation: fadeInDown 0.6s ease-out;
      }
      .animate-fade-in-up {
        animation: fadeInUp 0.6s ease-out;
      }
      .animate-slide-in-right {
        animation: slideInRight 0.6s ease-out;
      }
      .glow-text {
        animation: glow 3s ease-in-out infinite;
      }
    </style>
  </head>

  <body class="bg-background text-foreground">
    <Header />

    <!-- Hero Section -->
    <section id="hero" class="relative min-h-screen flex items-center justify-center overflow-hidden bg-gradient-to-b from-background via-background to-card/20">
