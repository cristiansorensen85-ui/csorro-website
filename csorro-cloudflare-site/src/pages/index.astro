---
import '../styles/global.css';

const title = 'Cristian Sorensen | Operations, Production & Technical Project Manager';
const description = 'Operations, production and technical project manager helping creators, communities and teams turn ambitious ideas into successful productions.';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://www.csorro.co.uk" />
  </head>
  <body>
    <nav class="nav">
      <div class="container nav-inner">
        <a class="brand" href="#top" aria-label="C Sorro home">
          <img src="/images/c-sorro-logo.png" alt="C Sorro logo" />
          <span>C Sorro</span>
        </a>
        <div class="nav-links">
          <a href="#story">Story</a>
          <a href="#impact">Impact</a>
          <a href="#work">Work</a>
          <a href="#people">People</a>
          <a href="#contact">Contact</a>
        </div>
      </div>
    </nav>

    <main id="top">
      <section class="hero cinematic">
        <div class="container hero-grid">
          <div class="hero-copy">
            <div class="eyebrow">Operations • Production • Technical Delivery</div>
            <h1>Helping ambitious ideas become <span class="gradient-text">successful productions.</span></h1>
            <p class="lead">I'm Cristian Sorensen — an operations, production and technical project manager who helps creators, communities and teams bring complex projects to life through planning, people, systems and delivery.</p>
            <div class="hero-actions">
              <a class="btn" href="/cv.pdf">Download CV</a>
              <a class="btn secondary" href="mailto:contact@csorro.co.uk">Contact Me</a>
            </div>
            <div class="pill-row">
              <span class="pill">Production Management</span>
              <span class="pill">Operations Management</span>
              <span class="pill">Technical Project Management</span>
              <span class="pill">Community Leadership</span>
            </div>
          </div>
          <div class="hero-card portrait-card">
            <img src="/images/cristian-sorensen.png" alt="Cristian Sorensen" />
            <div class="float-card">
              <strong>200M+</strong>
              Collective YouTube views across productions and media projects I've contributed to.
            </div>
          </div>
        </div>
      </section>

      <section id="impact" class="section compact-section">
        <div class="container">
          <div class="stats impact-stats">
            <div class="stat hero-stat"><strong>200M+</strong><span>Collective YouTube views across productions and projects contributed to</span></div>
            <div class="stat"><strong>120M+</strong><span>Counted from RyanNotBrian production work before stopping the count</span></div>
            <div class="stat"><strong>5+ yrs</strong><span>Paid professional production, operations and project experience</span></div>
            <div class="stat"><strong>1000s</strong><span>Players, contributors and community members supported</span></div>
          </div>
        </div>
      </section>

      <section id="story" class="section story">
        <div class="container story-grid">
          <div>
            <div class="eyebrow">The Person Behind The Projects</div>
            <p class="quote">I thrive where creativity, technology and people meet.</p>
          </div>
          <div class="copy">
            <p>My work has always sat behind the scenes: planning projects, supporting creators, organising communities, building systems, solving technical problems and helping ambitious productions reach the finish line.</p>
            <p>For over a decade I've been involved in gaming communities, content creation and online projects. Over the last several years that experience became professional production, operations and project work — supporting creator-led productions, multiplayer events, technical infrastructure, Discord communities and international teams.</p>
            <p>I am not trying to be known as a developer. I can build technical tools when they are needed, but the real value is in understanding the goal, organising the people, creating the process and making sure the project actually gets delivered.</p>
            <p>When everything is finished, uploaded and people finally get to watch it, I read the comments and take pride in what <strong>we</strong> made. That's what drives me: helping creators, teams and communities turn ideas into something people remember.</p>
          </div>
        </div>
      </section>

      <section id="what-i-do" class="section">
        <div class="container">
          <div class="section-header">
            <div class="eyebrow">What I Do</div>
            <h2>People, projects, creators, planning, productions and communities.</h2>
            <p>I help turn big, messy ideas into structured projects with clear responsibilities, reliable systems, better communication and production-ready delivery.</p>
          </div>
          <div class="grid-3">
            <div class="card"><div class="icon">🎬</div><h3>Production Management</h3><p>Planning and supporting creator-led productions from concept through build, recording, delivery and release.</p></div>
            <div class="card"><div class="icon">🧭</div><h3>Operations Management</h3><p>Building structure across teams, Discords, staff, contributors and communities so projects keep moving.</p></div>
            <div class="card"><div class="icon">⚙️</div><h3>Technical Project Delivery</h3><p>Managing infrastructure, servers, systems, automation and troubleshooting to support production goals.</p></div>
            <div class="card"><div class="icon">🌍</div><h3>World & Experience Design</h3><p>Helping create immersive worlds, lore, game modes, player journeys and recording environments.</p></div>
            <div class="card"><div class="icon">🤝</div><h3>Community Leadership</h3><p>Supporting players, staff and contributors, onboarding people and building communities that can contribute successfully.</p></div>
            <div class="card"><div class="icon">📣</div><h3>Media & Communication</h3><p>Podcasting, football discussion, public communication and live media experience alongside production work.</p></div>
          </div>
        </div>
      </section>

      <section id="work" class="section productions-section">
        <div class="container">
          <div class="section-header">
            <div class="eyebrow">What I've Helped Deliver</div>
            <h2>Large-scale productions, creator operations and community systems.</h2>
            <p>This is not about one platform or one plugin. The work is about taking ideas and building the operational, creative and technical foundations needed to make them happen.</p>
          </div>
          <div class="grid-2">
            <article class="card production-card feature-card">
              <div><span class="tag">Creator Ecosystem</span><h3>RyanNotBrian production & operations</h3><p>Supported the wider operation around RyanNotBrian productions, including production planning, community and Discord management, technical infrastructure, event readiness, contributor coordination, creator support and external opportunities.</p></div>
              <div class="meta"><span>Production Ops</span><span>Discord</span><span>Infrastructure</span><span>Creator Support</span></div>
            </article>
            <article class="card production-card feature-card">
              <div><span class="tag">Major Production Series</span><h3>Medieval War and long-form creator productions</h3><p>Helped manage a complex multi-video production across a long period, involving large groups of players, teams, lore, world-building, technical systems, recording logistics and community coordination. The series alone reached over 30 million combined views.</p></div>
              <div class="meta"><span>Lore</span><span>Teams</span><span>Planning</span><span>Delivery</span></div>
            </article>
            <article class="card production-card feature-card">
              <div><span class="tag">End-to-End Build</span><h3>Zombie War</h3><p>Created a full world and production environment over three months, including cities, infrastructure, mod setup, system settings and production preparation, followed by around two months of recording, support and b-roll/editing work.</p></div>
              <div class="meta"><span>World Creation</span><span>Systems</span><span>Recording Support</span><span>B-roll</span></div>
            </article>
            <article class="card production-card feature-card">
              <div><span class="tag">Production Systems</span><h3>Bespoke operational tooling</h3><p>Designed and built internal tools to reduce repetitive administration, improve player experience, speed up event setup, support staff and make creator productions easier to run. The tools matter because they removed friction for people.</p></div>
              <div class="meta"><span>Automation</span><span>Workflow</span><span>Admin Support</span><span>Live Ops</span></div>
            </article>
            <article class="card production-card feature-card">
              <div><span class="tag">Worlds & Game Modes</span><h3>Modded War, Medieval War and survival experiences</h3><p>Helped build full production environments from concept to release: worlds, systems, lore, gameplay rules, community processes, technical setup and recording support — creating spaces where players and creators could tell memorable stories.</p></div>
              <div class="meta"><span>Game Design</span><span>Worlds</span><span>Community</span><span>Operations</span></div>
            </article>
            <article class="card production-card feature-card">
              <div><span class="tag">Media & Community</span><h3>Football, podcasting and public discussion</h3><p>Contributor to To Hull And Back, discussing Hull City AFC, football culture and supporter perspectives. This adds public communication, broadcasting and community media experience alongside technical and production operations.</p></div>
              <div class="meta"><span>Podcasting</span><span>Football Media</span><span>Communication</span><span>Community</span></div>
            </article>
          </div>
        </div>
      </section>

      <section class="section visual-strip-section">
        <div class="container">
          <div class="section-header">
            <div class="eyebrow">Trusted Environments</div>
            <h2>Creator, studio and media work.</h2>
            <p>Some of the creator, studio and media environments connected to my production, operations and communication experience.</p>
          </div>
          <div class="logo-strip">
            <div class="logo-card"><img src="/images/ryannotbrian-logo.png" alt="RyanNotBrian" /></div>
            <div class="logo-card"><img src="/images/blackshores-logo.png" alt="BlackShore Studios" /></div>
            <div class="logo-card"><img src="/images/blackshores-survivingryan.png" alt="Surviving Ryan" /></div>
            <div class="logo-card"><img src="/images/to-hull-and-back-logo.png" alt="To Hull And Back" /></div>
          </div>
          <div class="image-duo">
            <img src="/images/ryannotbrian-videos.png" alt="RyanNotBrian productions" />
            <img src="/images/to-hull-and-back-me.png" alt="Cristian Sorensen podcast appearance" />
          </div>
        </div>
      </section>

      <section id="people" class="section story">
        <div class="container">
          <div class="section-header">
            <div class="eyebrow">Community Impact</div>
            <h2>It's all about the people.</h2>
            <p>The best part of production work is seeing the people involved succeed, then watching the audience react to something the whole team helped create.</p>
          </div>
          <div class="testimonial-grid">
            <div class="testimonial"><img src="/images/discord-comment-1.png" alt="Discord community comment" /></div>
            <div class="testimonial"><img src="/images/discord-comment-2.png" alt="Discord community comment" /></div>
            <div class="testimonial"><img src="/images/discord-comment-3.png" alt="Discord community comment" /></div>
          </div>
          <div class="testimonial-grid secondary-testimonials">
            <div class="testimonial"><img src="/images/discord-comment-4.png" alt="Discord community comment" /></div>
            <div class="testimonial"><img src="/images/discord-comment-5.png" alt="Discord community comment" /></div>
            <div class="testimonial"><img src="/images/discord-comment-6.png" alt="Discord community comment" /></div>
          </div>
        </div>
      </section>

      <section class="section philosophy-section">
        <div class="container philosophy-card">
          <div class="eyebrow">How I Work</div>
          <h2>I build the conditions that let creative people do their best work.</h2>
          <p>I enjoy removing complexity. Sometimes that means planning a production. Sometimes it means calming a community. Sometimes it means building a technical system. Sometimes it means creating a world, writing lore, organising players or fixing a problem minutes before recording. Whatever the task, the goal is the same: help the team deliver something everyone can be proud of.</p>
        </div>
      </section>

      <section id="contact" class="section contact-section">
        <div class="container">
          <div class="card contact-card">
            <div class="eyebrow">Let's Build Something</div>
            <h2>Need someone who can help make a project happen?</h2>
            <p>I'm interested in production management, operations management, technical project management, creator support, gaming operations, community leadership and helping creators turn ambitious ideas into reality.</p>
            <div class="hero-actions center-actions">
              <a class="btn" href="mailto:contact@csorro.co.uk">Contact Me</a>
              <a class="btn secondary" href="/cv.pdf">Download CV</a>
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer class="footer">
      <div class="container footer-inner">
        <div>© {new Date().getFullYear()} Cristian Sorensen / C Sorro</div>
        <div>Operations • Production • Community • Technical Delivery</div>
      </div>
    </footer>
  </body>
</html>
